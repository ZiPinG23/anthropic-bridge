PORT=8083

# Bridge authentication (optional, comma-separated for multiple keys)
BRIDGE_API_KEYS=sk-bridge-local

# Upstream API (OpenAI-compatible)
COMPANY_BASE_URL=https://your-api-gateway.example.com
COMPANY_CHAT_PATH=/v1/chat/completions
COMPANY_API_KEY=your-api-key-here
COMPANY_AUTH_HEADER=Authorization
COMPANY_AUTH_PREFIX="Bearer "
COMPANY_EXTRA_HEADERS=

# Models
DEFAULT_MODEL=Claude-sonnet-4.6
MODEL_MAP=
SUPPORTED_MODELS=Claude-sonnet-4.6,Claude-opus-4.6-global
